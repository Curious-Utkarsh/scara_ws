<?xml version="1.0" ?>
<robot name="scara" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="world"/>

    <!-- ── BASE ─────────────────────────────────────── -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/base_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="scara_mid_blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/base_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                               iyy="0.01" iyz="0.0"
                               izz="0.01"/>
        </inertial>
    </link>

    <joint name="base_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="world"/>
        <child link="base_link"/>
    </joint>

    <!-- ── COLUMN ────────────────────────────────────── -->
    <link name="column_link">
        <visual>
            <origin xyz="-0.045 0 -0.089" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/column_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="scara_mid_blue"/>
        </visual>
        <collision>
            <origin xyz="-0.045 0 -0.089" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/column_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.045 0 -0.089" rpy="0 0 0"/>
            <mass value="4.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                               iyy="0.01" iyz="0.0"
                               izz="0.01"/>
        </inertial>
    </link>

    <joint name="column_joint" type="revolute">
        <origin xyz="0.045 0 0.089" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="column_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="1.5"/>
    </joint>

    <!-- ── SHOULDER ──────────────────────────────────── -->
    <link name="shoulder_link">
        <visual>
            <origin xyz="-0.045 0 -0.39" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/shoulder_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="scara_mid_blue"/>
        </visual>
        <collision>
            <origin xyz="-0.045 0 -0.39" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/shoulder_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.045 0 -0.39" rpy="0 0 0"/>
            <mass value="3.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                               iyy="0.01" iyz="0.0"
                               izz="0.01"/>
        </inertial>
    </link>

    <joint name="shoulder_joint" type="prismatic">
        <origin xyz="0 0 0.28" rpy="0 0 0"/>
        <parent link="column_link"/>
        <child link="shoulder_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.12" upper="0.02" effort="100.0" velocity="0.5"/>
    </joint>

    <!-- ── FOREARM ───────────────────────────────────── -->
    <link name="forearm_link">
        <visual>
            <origin xyz="-0.273 0 -0.351" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/forearm_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="scara_mid_blue"/>
        </visual>
        <collision>
            <origin xyz="-0.273 0 -0.351" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/forearm_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.273 0 -0.351" rpy="0 0 0"/>
            <mass value="2.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                               iyy="0.01" iyz="0.0"
                               izz="0.01"/>
        </inertial>
    </link>

    <joint name="forearm_joint" type="revolute">
        <origin xyz="0.228 0 -0.04" rpy="0 0 0"/>
        <parent link="shoulder_link"/>
        <child link="forearm_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="1.5"/>
    </joint>

    <!-- ── WRIST ─────────────────────────────────────── -->
    <link name="wrist_link">
        <visual>
            <origin xyz="-0.4095 0 -0.291" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/wrist_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="scara_dark_blue"/>
        </visual>
        <collision>
            <origin xyz="-0.4095 0 -0.291" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/wrist_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.4095 0 -0.291" rpy="0 0 0"/>
            <mass value="1.5"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                               iyy="0.01" iyz="0.0"
                               izz="0.01"/>
        </inertial>
    </link>

    <joint name="wrist_joint" type="revolute">
        <origin xyz="0.1365 0 -0.06" rpy="0 0 0"/>
        <parent link="forearm_link"/>
        <child link="wrist_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="1.5"/>
    </joint>

    <!-- ── LEFT FINGER ───────────────────────────────── -->
    <link name="left_finger_link">
        <visual>
            <origin xyz="-0.409 -0.0626 -0.2775" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/left_finger_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="scara_light_grey"/>
        </visual>
        <collision>
            <origin xyz="-0.409 -0.0626 -0.2775" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/left_finger_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.409 -0.0626 -0.2775" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                               iyy="0.01" iyz="0.0"
                               izz="0.01"/>
        </inertial>
    </link>

    <!-- MASTER GRIPPER JOINT -->
    <joint name="left_finger_joint" type="prismatic">
        <origin xyz="0 0.064 -0.0135" rpy="0 0 0"/>
        <parent link="wrist_link"/>
        <child link="left_finger_link"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.02" upper="0.0" effort="100.0" velocity="0.5"/>
    </joint>

    <!-- ── RIGHT FINGER ──────────────────────────────── -->
    <link name="right_finger_link">
        <visual>
            <origin xyz="-0.409 0.0626 -0.2775" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/right_finger_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="scara_light_grey"/>
        </visual>
        <collision>
            <origin xyz="-0.409 0.0626 -0.2775" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/right_finger_link.stl"
                      scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.409 0.0626 -0.2775" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                               iyy="0.01" iyz="0.0"
                               izz="0.01"/>
        </inertial>
    </link>

    <!-- MIMIC JOINT -->
    <joint name="right_finger_joint" type="prismatic">
        <origin xyz="0 -0.064 -0.0135" rpy="0 0 0"/>
        <parent link="wrist_link"/>
        <child link="right_finger_link"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-0.02" upper="0.0" effort="100.0" velocity="0.5"/>
        <mimic joint="left_finger_joint" multiplier="1.0" offset="0.0"/>
    </joint>

</robot>
