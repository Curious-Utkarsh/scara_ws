<?xml version="1.0" ?>
<robot name="scara" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="world"/>

    <link name="base_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="grey">
                <color rgba="0.8 0.8 0.8 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="base_joint" type="fixed">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="world"/>
        <child link="base_link"/>
    </joint>

    <link name="column_link">
        <visual>
            <origin xyz="-0.045 0.0 -0.089" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/column_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="grey">
                <color rgba="0.8 0.8 0.8 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="column_joint" type="revolute">
        <origin xyz="0.045 0.0 0.089" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="column_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="1.5" />
    </joint>

    <link name="shoulder_link">
        <visual>
            <origin xyz="-0.045 0.0 -0.39" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/shoulder_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="grey">
                <color rgba="0.8 0.8 0.8 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="shoulder_joint" type="prismatic">
        <origin xyz="0.0 0.0 0.28" rpy="0.0 0.0 0.0"/>
        <parent link="column_link"/>
        <child link="shoulder_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="100.0" velocity="0.5" lower="0.0" upper="-0.21"/>
    </joint>

    <link name="forearm_link">
        <visual>
            <origin xyz="-0.273 0.0 -0.351" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://scara_description/meshes/forearm_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="grey">
                <color rgba="0.8 0.8 0.8 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="forearm_joint" type="revolute">
        <origin xyz="0.228 0.0 -0.04" rpy="0.0 0.0 0.0"/>
        <parent link="shoulder_link"/>
        <child link="forearm_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="1.5" />

    </joint>

</robot>