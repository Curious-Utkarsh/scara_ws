<?xml version="1.0" ?>
<robot name="scara" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Load Simulated or Real Hardware Interfaces -->
    <xacro:arg name="is_sim" default="true"/>

    <xacro:include filename="$(find scara_description)/urdf/arm.xacro" />
    <xacro:include filename="$(find scara_description)/urdf/gazebo.xacro" />
    <xacro:include filename="$(find scara_description)/urdf/ros2control.xacro" />
    
</robot>