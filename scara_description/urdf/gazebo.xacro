<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="scara">

    <!-- Declare args with defaults so xacro never errors if caller omits them -->
    <xacro:arg name="is_sim"      default="true"/>
    <xacro:arg name="is_ignition" default="false"/>

    <xacro:if value="$(arg is_sim)">

        <xacro:if value="$(arg is_ignition)">
            <!-- ROS 2 Humble + Ignition Fortress -->
            <gazebo>
                <plugin filename="ign_ros2_control-system"
                        name="ign_ros2_control::IgnitionROS2ControlPlugin">
                    <parameters>$(find scara_controller)/config/scara_controllers.yaml</parameters>
                </plugin>
                <plugin filename="ignition-gazebo-sensors-system"
                        name="ignition::gazebo::systems::Sensors">
                    <render_engine>ogre2</render_engine>
                </plugin>
            </gazebo>
        </xacro:if>

        <xacro:unless value="$(arg is_ignition)">
            <!-- ROS 2 Iron+ + Gazebo Garden/Harmonic -->
            <gazebo>
                <plugin filename="gz_ros2_control-system"
                        name="gz_ros2_control::GazeboSimROS2ControlPlugin">
                    <parameters>$(find scara_controller)/config/scara_controllers.yaml</parameters>
                </plugin>
                <plugin filename="gz-sim-sensors-system"
                        name="gz::sim::systems::Sensors">
                    <render_engine>ogre2</render_engine>
                </plugin>
            </gazebo>
        </xacro:unless>

    </xacro:if>

    <!-- <gazebo reference="camera_link">
        <sensor name="camera" type="camera">
            <pose>0 0 0 0 0 0 </pose>
            <visualize>true</visualize>
            <update_rate>10.0</update_rate>
            <alwaysOn>true</alwaysOn>
            <topic>camera/image_raw</topic>
            <gz_frame_id>camera_link_optical</gz_frame_id>
            <camera name="intel_realsense_r200">
                <camera_info_topic>camera/camera_info</camera_info_topic>
                <horizontal_fov>1.3962634</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.05</near>
                    <far>8.0</far>
                </clip>
            </camera>
        </sensor>
    </gazebo> -->

    <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <update_rate>10.0</update_rate>
        <alwaysOn>true</alwaysOn>
        <topic>camera/image_raw</topic>
        <gz_frame_id>camera_link_optical</gz_frame_id>

        <camera name="intel_realsense_r200">
        <camera_info_topic>camera/camera_info</camera_info_topic>
        <horizontal_fov>1.3962634</horizontal_fov>

        <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
        </image>

        <clip>
            <near>0.05</near>
            <far>8.0</far>
        </clip>

        <depth_camera>
            <output>depths</output>
        </depth_camera>
        </camera>
    </sensor>
    </gazebo>

</robot>
